{% extends 'base.html.twig' %}

{% block title %}Équipe — TaskLinker{% endblock %}

{% block page_title %}Équipe{% endblock %}

{% block content %}
    <table id="team-container">
        <thead>
            <tr>
                <th>Prénom, Nom</th>
                <th>Statut</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for employee in employees %}
                <tr>
                    <td>
                        <div class="employee-infos">
                            <div class="employee-avatar">
                                {{ employee.firstName|slice(0, 1) }}{{ employee.lastName|slice(0, 1) }}
                            </div>
                            <div class="employee-coords">
                                <strong>{{ employee.firstName }} {{ employee.lastName }}</strong>
                                <span>{{ employee.mail }}</span>
                            </div>
                        </div>
                    </td>
                    <td>{{ employee.typeContract.label }}</td>
                    <td>
                        <a class="button button-edit-team" href="{{ path('app_employee_edit_get', { id: employee.id }) }}">Éditer</a>
                        <form method="post" action="{{ path('app_employee_delete', { id: employee.id }) }}">
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="delete-team">Supprimer</button>
                        </form>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3">Aucun employé trouvé.</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endblock %}